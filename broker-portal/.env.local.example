# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase Service Role Key (server-side only, NEVER expose to browser)
# Required for impersonation token validation and data loading
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Portal URL (used for redirect after ending impersonation session)
NEXT_PUBLIC_ADMIN_PORTAL_URL=https://admin.keeprcompliance.com

# Microsoft Clarity (analytics) — optional, omit to disable
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id
