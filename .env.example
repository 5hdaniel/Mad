# Keepr Desktop App - Environment Variables
# Copy to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.

# --- Required ---

# Supabase project URL and anonymous (public) key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# --- Optional (feature-specific) ---

# Broker Portal URL (defaults to production if not set)
BROKER_PORTAL_URL=http://localhost:3001

# Microsoft / Outlook integration (Azure AD app registration)
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_TENANT_ID=common

# Google / Gmail integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps / Places API (address verification)
GOOGLE_MAPS_API_KEY=your_api_key_here

# Sentry error tracking
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Sentry auth token (build-time source map upload only)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
