# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (server-side only, never expose to client)
# Required for the invite internal user flow (POST /api/internal-users/invite)
# Find this in: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Broker Portal URL (for impersonation "View as User" feature)
NEXT_PUBLIC_BROKER_PORTAL_URL=http://localhost:3001

# Sentry SDK (error tracking — optional, omit to disable)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token  # Only needed for source map uploads

# Sentry REST API (optional - user detail view will degrade gracefully without these)
SENTRY_API_TOKEN=sntrys_your-sentry-api-token
SENTRY_ORG_SLUG=keeprcompliancecom
